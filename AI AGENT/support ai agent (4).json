        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{ $('Webhook').item.json.body.data.key.remoteJid }}\",\n  \"audio\": \"https://drive.google.com/uc?export=download&id=1mwT1LFnP1bRxafw7RVY-PqjLrIiijKZO\",\n  \"delay\": 1500,\n  \"encoding\": true,\n  \"ptt\": true\n}",
