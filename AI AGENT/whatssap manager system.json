        "jsCode": "const text = $input.first().json.cleanText;\nconst maxChars = 1500;\n\nlet paragraphs = text.split(/\\n\\s*\\n/);\n\nlet chunks = [];\nlet current = \"\";\nfor (let p of paragraphs) {\n\n  if ((current + p).length < maxChars) {\n    current += \"\\n\\n\" + p;\n  } else {\n    chunks.push({ json: { chunk: current.trim() } });\n    current = p;\n  }\n}\n\nif (current) {\n  chunks.push({ json: { chunk: current.trim() } });\n}\n\nreturn chunks;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
