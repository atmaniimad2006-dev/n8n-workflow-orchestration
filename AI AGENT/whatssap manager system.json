      "name": "Message a model"
    },
    {
      "parameters": {
        "jsCode": "const allQna = [];\n\nfor (const item of $input.all()) {\n  let extractedData = null;\n\n  // 1. Njebdou l'data mn dak l'massar l'mkhbbe3 (kima f tsweera 4)\n  if (item.json.output && Array.isArray(item.json.output) && item.json.output[0].content) {\n      extractedData = item.json.output[0].content[0].text;\n  } else {\n      extractedData = item.json.text || item.json.output;\n  }\n\n  if (!extractedData) continue;\n\n  try {\n    let data;\n    \n    // 2. Hada howa l'Fix: n8n b3d lmerrat kay-parsi l'JSON bo7do\n    if (typeof extractedData === 'object' && extractedData !== null) {\n        data = extractedData; // Rah deja object, makhasnach n-parsiweh\n    } else if (typeof extractedData === 'string') {\n        // N9iweh w n-parsiweh ila kan string\n        let cleaned = extractedData.replace(/```json/gi, \"\").replace(/```/g, \"\").trim();\n        data = JSON.parse(cleaned);\n    }\n\n    // 3. Nferr9ou les Q&A\n    if (data && data.qna && Array.isArray(data.qna)) {\n      data.qna.forEach(qa => {\n        allQna.push({\n          json: {\n            pinecone_content: `Question: ${qa.question}\\nRéponse: ${qa.answer}`,\n            source: \"Workflow_Ingestion\"\n          }\n        });\n      });\n    }\n  } catch (error) {\n    // ⚠️ L'Anti-Piège: Ila wq3 mochkil db, aytkteb lik f l'output bach nchoufouh!\n    allQna.push({\n        json: {\n            DEBUG_ERROR: \"Parsing failed\",\n            DETAILS: error.message,\n            RAW: extractedData\n        }\n    });\n  }\n}\n\nreturn allQna;"
      },
