      "parameters": {
        "jsCode": "// Extraction des données du Webhook d'origine\nconst webhookData = $('Webhook').first().json.body.data;\n\n// Extraction du base64 (Evolution API l'injecte ici avec l'option Webhook Base64)\nconst imageBase64 = webhookData.message.base64;\nconst mimeType = webhookData.message.imageMessage.mimetype || 'image/jpeg';\n\nif (!imageBase64) {\n  throw new Error(\"Base64 introuvable dans le webhook. Vérifie qu'Evolution API envoie bien l'image.\");\n}\n\nreturn [{\n  json: $input.item.json,\n  binary: {\n    data: {\n      data: imageBase64,\n      mimeType: mimeType,\n      fileName: \"proof.jpeg\"\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1424,
        432
      ],
      "id": "a56c086c-8eba-4211-b0da-b4e08a7710a2",
      "name": "Code in JavaScript9"
    },
    {
      "parameters": {
        "jsCode": "// 1. Extraction d l-waqt mn Evolution API (Timestamp)\nconst msg_timestamp = $node[\"Webhook\"]?.json?.body?.data?.messageTimestamp;\nif (!msg_timestamp) throw new Error(\"Timestamp introuvable dans le webhook.\");\nconst date_obj = new Date(msg_timestamp * 1000);\n\n// 2. Fetch l-Data mn Google Sheets b-Protection\n// Ila l-client ma-msjelch, sheetData ghatkoun objet khawi bla may-crashi\nconst sheetData = $node[\"Get row(s) in sheet4\"]?.json || {};\nconst user_tz = sheetData[\"TIME ZONE\"] || \"Africa/Casablanca\";\n\n// 3. Calcul de la Date Exacte (Timezone-Aware) - THE CORE\nconst formatter = new Intl.DateTimeFormat('en-CA', { \n    timeZone: user_tz, \n    year: 'numeric', \n    month: '2-digit', \n    day: '2-digit' \n});\nconst local_date_str = formatter.format(date_obj);\n\n// 4. Extraction l-Caption w Validation b-Protection\n// Optional chaining (?.) kay-protegi l-code mn l-crash ila makanch imageMessage\nconst caption = ($node[\"Webhook\"]?.json?.body?.data?.message?.imageMessage?.caption || \"\").toLowerCase();\nlet task_type = \"None\";\nlet is_valid = false;\n\n// Routing direct\nif (caption.includes(\"fajr\")) {\n    task_type = \"Fajr\";\n    is_valid = true;\n} else if (caption.includes(\"quran\")) {\n    task_type = \"Quran\";\n    is_valid = true;\n} else if (caption.includes(\"deepwork\")) {\n    task_type = \"DeepWork\";\n    is_valid = true;\n}\n\n// 5. Output l Google Drive w Google Sheets\nreturn [{\n    json: {\n        date: local_date_str, \n        task: task_type,\n        valid: is_valid,\n        phone: sheetData.Phone_Number || \"UNKNOWN_PHONE\",\n        drive_folder: sheetData.Drive_Folder_ID || \"UNKNOWN_FOLDER\",\n        timezone: user_tz \n    },\n    binary: $('Code in JavaScript9').first().binary \n}];"
      },
